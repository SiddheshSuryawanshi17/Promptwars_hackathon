{
  "name": "venueflow-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.11.0",
    "socket.io-client": "^4.5.4",
    "tailwindcss": "^3.2.7",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.24",
    "lucide-react": "^0.263.1",
    "recharts": "^2.7.2",
    "@react-google-maps/api": "^2.18.1",
    "axios": "^1.4.0",
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "mongoose": "^7.1.0",
    "stripe": "^12.0.0",
    "web-push": "^3.6.5",
    "jwt-decode": "^3.1.2"
  },
  "scripts": {
    "verify": "node verify.js",
    "setup": "node setup.js",
    "start": "react-scripts start",
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "all": "concurrently \"npm run server\" \"npm start\"",
    "docker:build": "docker build -t venueflow .",
    "docker:run": "docker run -p 5000:5000 -p 3000:3000 venueflow",
    "docker:compose": "docker-compose -f docker-compose.simple.yml up"
